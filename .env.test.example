# IndustrySignal — E2E environment overrides.
#
# Copy to `.env.test` (gitignored) if you need to point Playwright at a
# different database than the docker-compose default. The Playwright
# config also accepts these as inline env vars at invocation time.

# Postgres connection for the E2E DB. The default below matches the
# docker-compose service in `docker-compose.yml`.
E2E_DATABASE_URL=postgres://industrysignal:industrysignal@localhost:5433/industrysignal

# Optional — alternate port for `next dev` so it doesn't clash with a
# developer's running `pnpm dev` on 3000.
E2E_PORT=3001

# Auth.js requires a non-empty secret; the value itself doesn't matter
# inside the test sandbox.
AUTH_SECRET=e2e-secret-not-for-production
