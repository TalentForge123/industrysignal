{
  "name": "industrysignal",
  "version": "0.0.0",
  "private": true,
  "description": "IndustrySignal — B2B intelligence platform for Czech industry. Monorepo root.",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
