# IndustrySignal — environment variables.
#
# Copy to `.env.local` (gitignored) and fill in. Drizzle-kit + the Next
# portal both load from the repo root via packages/db/drizzle.config.ts
# and Next's built-in dotenv pipeline.

# ----- Database -----------------------------------------------------------
# Postgres connection string. Neon (production) or local docker postgres.
# Format: postgres://user:password@host:port/database?sslmode=require
DATABASE_URL=postgres://placeholder/placeholder

# ----- Auth (wired up in Sprint 1, commit 4) ------------------------------
# Auth.js v5 — secret used to sign JWT session cookies. Generate with
#   openssl rand -base64 32
AUTH_SECRET=

# Postmark API token for transactional email (magic-link delivery).
# Sender domain must be DKIM-verified in Postmark before first send.
POSTMARK_TOKEN=
POSTMARK_FROM_EMAIL=portal@industrysignal.cz

# ----- Anthropic (wired up in Sprint 4 — Studio editorial pipeline) -------
ANTHROPIC_API_KEY=

# ----- Connectors (wired up in Sprint 2) ----------------------------------
# ČSÚ and other free CZ registries require a contact UA per their TOS.
ARES_USER_AGENT=IndustrySignal-Bot/1.0 (sevcik@svetprumyslu.cz; https://industrysignal.cz/bot)
